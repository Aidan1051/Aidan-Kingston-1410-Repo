String[] to OppositeArray(int[] numbers){
    String[] opposite = new String[numbers.length];
    for (int i = 0; i < numbers.length;  i++) {
        opposite[i] = String.valueOf(numbers[numbers.length-1-i]);
    }
    return opposite;
}

